rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isStudent()  { return isAuth() && getRole() == "student"; }
    function isParent()   { return isAuth() && getRole() == "parent"; }
    function isEducator() { return isAuth() && getRole() == "educator"; }
    function isStaff()    { return isAuth() && (getRole() == "educator" || getRole() == "admin"); }

    // Child linked to parent
    function isMyChild(studentUid) {
      return isParent() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childUid == studentUid;
    }

    // Student belongs to educator's class
    function isMyStudent(studentUid) {
      return isStaff() &&
        exists(/databases/$(database)/documents/studentProfiles/$(studentUid)) &&
        get(/databases/$(database)/documents/studentProfiles/$(studentUid)).data.educatorUid == request.auth.uid;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isStaff() || isMyChild(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isStaff();
    }

    // ── schools ───────────────────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow read:  if isAuth();
      allow write: if isStaff();
    }

    // ── classes ───────────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read:  if isAuth();
      allow write: if isStaff();

      match /students/{studentUid} {
        allow read:  if isAuth();
        allow write: if isStaff();
      }
    }

    // ── missions (templates) ──────────────────────────────────────────────────
    match /missions/{missionId} {
      allow read:  if isAuth();
      allow write: if isStaff();
    }

    // ── studentProfiles ───────────────────────────────────────────────────────
    match /studentProfiles/{studentUid} {
      allow read:  if isOwner(studentUid) || isMyChild(studentUid) || isMyStudent(studentUid) || isStaff();
      allow write: if isOwner(studentUid) || isStaff();

      // Mission progress — student writes own, educator can read all
      match /missionProgress/{missionId} {
        allow read:  if isOwner(studentUid) || isMyChild(studentUid) || isMyStudent(studentUid);
        allow write: if isOwner(studentUid) || isStaff();
      }

      // Tarbiyah daily check-ins — private to student, readable by parent/educator
      match /tarbiyah/{date} {
        allow read:  if isOwner(studentUid) || isMyChild(studentUid) || isMyStudent(studentUid);
        allow write: if isOwner(studentUid);
      }

      // AI chat sessions — private
      match /aiSessions/{sessionId} {
        allow read:  if isOwner(studentUid) || isStaff();
        allow write: if isOwner(studentUid);
      }

      // Weekly goals
      match /weeklyGoals/{weekId} {
        allow read:  if isOwner(studentUid) || isMyChild(studentUid) || isMyStudent(studentUid);
        allow write: if isOwner(studentUid) || isStaff();
      }
    }

    // ── attendance ────────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read:  if isAuth() && (
        isStaff() ||
        resource.data.studentUid == request.auth.uid ||
        isMyChild(resource.data.studentUid)
      );
      allow write: if isStaff();
    }

    // ── activityFeed ──────────────────────────────────────────────────────────
    match /activityFeed/{feedId} {
      allow read: if isAuth() && (
        resource.data.studentUid == request.auth.uid ||
        isMyChild(resource.data.studentUid) ||
        isMyStudent(resource.data.studentUid)
      );
      allow create: if isAuth();
      allow update, delete: if isStaff();
    }

    // ── messages ──────────────────────────────────────────────────────────────
    match /messages/{threadId} {
      allow read, write: if isAuth() && (
        request.auth.uid in resource.data.participantUids
      );
      allow create: if isAuth();

      match /messages/{msgId} {
        allow read:   if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() && resource.data.senderUid == request.auth.uid;
      }
    }

    // ── notifications ─────────────────────────────────────────────────────────
    match /notifications/{uid} {
      match /items/{itemId} {
        allow read:   if isOwner(uid);
        allow write:  if isOwner(uid) || isStaff();
      }
    }
  }
}
